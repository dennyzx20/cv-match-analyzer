OPENAI_API_KEY=sk-your-openai-api-key

# Optional. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# Admin-only local/test bypass. Keep false in production.
ADMIN_BYPASS_PAYMENT=false

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key

# Optional Stripe Price IDs. If missing, Checkout falls back to inline price_data.
STRIPE_BASE_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# Deprecated legacy fallback for Premium only.
STRIPE_PRICE_ID=

# Optional. Use this in production, e.g. https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
